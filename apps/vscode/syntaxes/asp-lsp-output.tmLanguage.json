{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Classic ASP LSP Output",
  "scopeName": "source.asp-lsp-output",
  "patterns": [
    {
      "include": "#operation"
    },
    {
      "include": "#state"
    },
    {
      "include": "#step"
    },
    {
      "include": "#uri"
    },
    {
      "include": "#duration"
    }
  ],
  "repository": {
    "operation": {
      "patterns": [
        {
          "match": "\\b(?:LSP analysis|LSP check|Formatting conversion)\\b",
          "name": "support.function.operation.asp-lsp-output"
        }
      ]
    },
    "state": {
      "patterns": [
        {
          "match": "\\b(?:started|completed)\\b",
          "name": "keyword.control.state.asp-lsp-output"
        }
      ]
    },
    "step": {
      "patterns": [
        {
          "match": "\\b(?:analysis|check|vbscript|format)(?:\\.[A-Za-z0-9_-]+)+\\b",
          "name": "entity.name.function.step.asp-lsp-output"
        }
      ]
    },
    "uri": {
      "patterns": [
        {
          "match": "\\bfile://[^\\s,)]*",
          "name": "markup.underline.link.uri.asp-lsp-output"
        }
      ]
    },
    "duration": {
      "patterns": [
        {
          "match": "\\bin\\s+(?:(?:[0-9]|[1-4][0-9])(?:\\.\\d+)?|50(?:\\.0+)?)\\s+ms\\b",
          "name": "constant.numeric.duration.asp-lsp-output.fast"
        },
        {
          "match": "\\bin\\s+(?:50\\.(?:[1-9]\\d*)|(?:5[1-9]|[6-9][0-9])(?:\\.\\d+)?|100(?:\\.0+)?)\\s+ms\\b",
          "name": "constant.numeric.duration.asp-lsp-output.medium"
        },
        {
          "match": "\\bin\\s+(?:100\\.(?:[1-9]\\d*)|(?:10[1-9]|1[1-9][0-9])(?:\\.\\d+)?|200(?:\\.0+)?)\\s+ms\\b",
          "name": "constant.numeric.duration.asp-lsp-output.slow"
        },
        {
          "match": "\\bin\\s+(?:200\\.(?:[1-9]\\d*)|20[1-9](?:\\.\\d+)?|2[1-9][0-9](?:\\.\\d+)?|[3-9][0-9]{2,}(?:\\.\\d+)?|[1-9][0-9]{3,}(?:\\.\\d+)?)\\s+ms\\b",
          "name": "constant.numeric.duration.asp-lsp-output.hot"
        }
      ]
    }
  }
}
