{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Classic ASP Tag Injection",
  "scopeName": "classic-asp.tag-injection",
  "injectionSelector": "L:text.html.classic-asp meta.tag, L:text.html.classic-asp meta.tag string.quoted",
  "patterns": [
    { "include": "#style-attribute-double" },
    { "include": "#style-attribute-single" },
    { "include": "#asp-expression" },
    { "include": "#asp-directive" },
    { "include": "#asp-block" }
  ],
  "repository": {
    "style-attribute-double": {
      "name": "meta.attribute.style.html",
      "begin": "(?i)\\b(style)\\b\\s*(=)\\s*(\")",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.html" },
        "2": { "name": "punctuation.separator.key-value.html" },
        "3": { "name": "punctuation.definition.string.begin.html" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.html" }
      },
      "contentName": "source.css.embedded.html",
      "patterns": [
        { "include": "#asp-expression" },
        { "include": "#asp-directive" },
        { "include": "#asp-block" },
        { "include": "#style-css" }
      ]
    },
    "style-attribute-single": {
      "name": "meta.attribute.style.html",
      "begin": "(?i)\\b(style)\\b\\s*(=)\\s*(')",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.html" },
        "2": { "name": "punctuation.separator.key-value.html" },
        "3": { "name": "punctuation.definition.string.begin.html" }
      },
      "end": "'",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.html" }
      },
      "contentName": "source.css.embedded.html",
      "patterns": [
        { "include": "#asp-expression" },
        { "include": "#asp-directive" },
        { "include": "#asp-block" },
        { "include": "#style-css" }
      ]
    },
    "style-css": {
      "patterns": [
        {
          "match": "(?i)\\b(-?[_a-z][_a-z0-9-]*)(\\s*)(:)",
          "captures": {
            "1": { "name": "support.type.property-name.css" },
            "3": { "name": "punctuation.separator.key-value.css" }
          }
        },
        {
          "match": ";",
          "name": "punctuation.terminator.rule.css"
        },
        {
          "match": "[^\"'<%;:]+",
          "name": "source.css.embedded.html"
        }
      ]
    },
    "asp-expression": {
      "name": "source.vbscript.embedded.asp.expression",
      "begin": "<%=",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.asp" }
      },
      "end": "%>",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.asp" }
      },
      "patterns": [{ "include": "#asp-vbscript" }]
    },
    "asp-directive": {
      "name": "meta.directive.asp",
      "begin": "<%@",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.asp" }
      },
      "end": "%>",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.asp" }
      },
      "patterns": [{ "include": "#asp-directive-content" }]
    },
    "asp-directive-content": {
      "patterns": [
        {
          "match": "(?i)\\b(Language|CodePage|LCID|Transaction|EnableSessionState)\\b",
          "name": "entity.other.attribute-name.directive.asp"
        },
        {
          "match": "=",
          "name": "punctuation.separator.key-value.directive.asp"
        },
        {
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.directive.asp" }
          },
          "end": "\"|(?=%>)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.directive.asp" }
          },
          "name": "string.quoted.double.directive.asp"
        },
        {
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.directive.asp" }
          },
          "end": "'|(?=%>)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.directive.asp" }
          },
          "name": "string.quoted.single.directive.asp"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.directive.asp"
        },
        {
          "match": "(?i)\\b(VBScript|JScript|JavaScript|True|False|Required|Requires_New|Supported|Not_Supported)\\b",
          "name": "constant.language.directive.asp"
        }
      ]
    },
    "asp-block": {
      "name": "source.vbscript.embedded.asp",
      "begin": "<%",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.asp" }
      },
      "end": "%>",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.asp" }
      },
      "patterns": [{ "include": "#asp-vbscript" }]
    },
    "asp-vbscript": {
      "patterns": [
        { "include": "#asp-vbscript-rem-comment" },
        { "include": "#asp-vbscript-string" },
        { "include": "#asp-vbscript-documentation-comment" },
        { "include": "#asp-vbscript-annotation-comment" },
        { "include": "#asp-vbscript-apostrophe-comment" },
        { "include": "source.vbscript" }
      ]
    },
    "asp-vbscript-rem-comment": {
      "begin": "(?i)(^|:)\\s*Rem\\b",
      "beginCaptures": {
        "0": { "name": "comment.line.rem.vbscript" }
      },
      "end": "(?=%>)|$",
      "name": "comment.line.rem.vbscript"
    },
    "asp-vbscript-string": {
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.vbscript" }
      },
      "end": "\"|(?=%>)",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.vbscript" }
      },
      "name": "string.quoted.double.vbscript"
    },
    "asp-vbscript-documentation-comment": {
      "begin": "(''')\\s?",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.vbscript" }
      },
      "end": "(?=%>)|$",
      "patterns": [
        { "include": "source.vbscript#documentation-tag" },
        { "include": "source.vbscript#documentation-entity" },
        {
          "match": "[^<&\\n\\r]+",
          "name": "string.unquoted.documentation.vbscript"
        }
      ]
    },
    "asp-vbscript-annotation-comment": {
      "begin": "(')\\s*(?=@(?:type|param|returns|member)\\b)",
      "beginCaptures": {
        "1": { "name": "comment.line.annotation.vbscript" }
      },
      "end": "(?=%>)|$",
      "patterns": [{ "include": "source.vbscript#annotation-comment" }]
    },
    "asp-vbscript-apostrophe-comment": {
      "begin": "'",
      "beginCaptures": {
        "0": { "name": "comment.line.apostrophe.vbscript" }
      },
      "end": "(?=%>)|$",
      "name": "comment.line.apostrophe.vbscript"
    }
  }
}
