{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VBScript",
  "scopeName": "source.vbscript",
  "patterns": [{ "include": "#vbscript-basic" }],
  "repository": {
    "vbscript-basic": {
      "patterns": [
        {
          "match": "(?i)(^|:)\\s*Rem\\b[^\\n\\r]*",
          "name": "comment.line.rem.vbscript"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.vbscript"
        },
        { "include": "#documentation-comment" },
        { "include": "#annotation-comment" },
        {
          "match": "'[^\\n\\r]*",
          "name": "comment.line.apostrophe.vbscript"
        },
        {
          "match": "(?i)\\b(?:(Public|Private)\\s+)?(Function|Sub)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.visibility.vbscript" },
            "2": { "name": "keyword.control.declaration.vbscript" },
            "3": { "name": "entity.name.function.vbscript" }
          }
        },
        {
          "match": "(?i)\\b(?:(Public|Private)\\s+)?(Property)\\s+(Get|Let|Set)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.visibility.vbscript" },
            "2": { "name": "keyword.control.declaration.vbscript" },
            "3": { "name": "keyword.control.accessor.vbscript" },
            "4": { "name": "entity.name.function.vbscript" }
          }
        },
        {
          "match": "(?i)\\b(As)\\s+(String|Variant|Number|Currency|Decimal|Error|Array|Boolean|Date|Object|Byte|Integer|Long|Single|Double)\\b",
          "captures": {
            "1": { "name": "keyword.control.vbscript" },
            "2": { "name": "support.type.vbscript" }
          }
        },
        {
          "match": "(?i)\\b(Option\\s+Explicit|And|As|ByRef|ByVal|Call|Case|Class|Const|Dim|Do|Each|Else|ElseIf|Empty|End|Error|Exit|Explicit|False|For|Function|Get|GoTo|If|In|Is|Let|Loop|Me|Mod|New|Next|Not|Nothing|Null|On|Option|Or|Preserve|Private|Property|Public|ReDim|Resume|Select|Set|Step|Sub|Then|To|True|Until|Wend|While|With)\\b",
          "name": "keyword.control.vbscript"
        },
        {
          "match": "\\b(Request|Response|Session|Application|Server|ASPError|Err)\\b",
          "name": "support.class.asp"
        },
        {
          "match": "\\b\\d+(?:\\.\\d+)?\\b",
          "name": "constant.numeric.vbscript"
        }
      ]
    },
    "documentation-comment": {
      "begin": "(''')\\s?",
      "beginCaptures": {
        "1": { "name": "comment.line.documentation.vbscript" }
      },
      "end": "$",
      "patterns": [
        { "include": "#documentation-tag" },
        { "include": "#documentation-entity" },
        {
          "match": "[^<&\\n\\r]+",
          "name": "string.unquoted.documentation.vbscript"
        }
      ]
    },
    "documentation-tag": {
      "begin": "(</?)([A-Za-z][A-Za-z0-9_-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.documentation.vbscript" },
        "2": { "name": "entity.name.tag.documentation.vbscript" }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.documentation.vbscript" }
      },
      "patterns": [
        {
          "match": "([A-Za-z][A-Za-z0-9_-]*)\\s*(=)\\s*(\"[^\"]*\"|'[^']*'|[^\\s\"'>/]+)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.documentation.vbscript" },
            "2": { "name": "punctuation.separator.key-value.documentation.vbscript" },
            "3": { "name": "string.quoted.documentation.vbscript" }
          }
        },
        { "include": "#documentation-entity" }
      ]
    },
    "documentation-entity": {
      "match": "&(?:[A-Za-z][A-Za-z0-9]+|#[0-9]+|#x[0-9A-Fa-f]+);",
      "name": "constant.character.entity.documentation.vbscript"
    },
    "annotation-comment": {
      "begin": "(')\\s*(?=@(?:type|param|returns|member)\\b)",
      "beginCaptures": {
        "1": { "name": "comment.line.annotation.vbscript" }
      },
      "end": "$",
      "patterns": [
        {
          "match": "(?i)(@type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(As)\\s+([^\\n\\r]+)",
          "captures": {
            "1": { "name": "keyword.other.annotation.vbscript" },
            "2": { "name": "variable.other.annotation.vbscript" },
            "3": { "name": "keyword.control.vbscript" },
            "4": { "name": "support.type.annotation.vbscript" }
          }
        },
        {
          "match": "(?i)(@param)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\.([A-Za-z_][A-Za-z0-9_]*))?\\s+(As)\\s+([^\\n\\r]+)",
          "captures": {
            "1": { "name": "keyword.other.annotation.vbscript" },
            "2": { "name": "variable.parameter.annotation.vbscript" },
            "3": { "name": "variable.parameter.member.annotation.vbscript" },
            "4": { "name": "keyword.control.vbscript" },
            "5": { "name": "support.type.annotation.vbscript" }
          }
        },
        {
          "match": "(?i)(@returns)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+([^\\n\\r]+)",
          "captures": {
            "1": { "name": "keyword.other.annotation.vbscript" },
            "2": { "name": "entity.name.function.annotation.vbscript" },
            "3": { "name": "support.type.annotation.vbscript" }
          }
        },
        {
          "match": "(?i)(@returns)(?:\\s+([^\\n\\r]+))?",
          "captures": {
            "1": { "name": "keyword.other.annotation.vbscript" },
            "2": { "name": "support.type.annotation.vbscript" }
          }
        },
        {
          "match": "(?i)(@member)\\s+([A-Za-z_][A-Za-z0-9_.]*)\\.([A-Za-z_][A-Za-z0-9_]*)\\s+(As)\\s+([^\\n\\r]+)",
          "captures": {
            "1": { "name": "keyword.other.annotation.vbscript" },
            "2": { "name": "entity.name.type.annotation.vbscript" },
            "3": { "name": "variable.other.member.annotation.vbscript" },
            "4": { "name": "keyword.control.vbscript" },
            "5": { "name": "support.type.annotation.vbscript" }
          }
        }
      ]
    }
  }
}
