{
  "name": "classic-asp-lsp",
  "displayName": "Classic ASP LSP",
  "version": "0.2.6",
  "private": true,
  "description": "%extension.description%",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "asp",
    "classic asp",
    "jscript",
    "language server",
    "vbscript"
  ],
  "homepage": "https://github.com/yottonoko/asp-lsp#readme",
  "bugs": {
    "url": "https://github.com/yottonoko/asp-lsp/issues"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yottonoko/asp-lsp.git"
  },
  "qna": false,
  "publisher": "yottonoko",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle-extension.mjs && node scripts/copy-server-runtime.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint src test --deny-warnings --no-error-on-unmatched-pattern",
    "package:vsix": "pnpm --filter @asp-lsp/core run build && pnpm --filter @asp-lsp/language-server run build && pnpm run build && vsce package --no-dependencies --follow-symlinks",
    "test": "pnpm --filter @asp-lsp/core run build && pnpm --filter @asp-lsp/language-server run build && pnpm run build && vitest run --passWithNoTests"
  },
  "dependencies": {
    "@asp-lsp/core": "workspace:*",
    "@asp-lsp/language-server": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1",
    "rolldown": "^1.0.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "classic-asp",
        "aliases": [
          "Classic ASP",
          "classic-asp",
          "ASP"
        ],
        "extensions": [
          ".asp",
          ".asa",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "vbscript",
        "aliases": [
          "VBScript",
          "vbscript"
        ]
      },
      {
        "id": "asp-lsp-output",
        "aliases": [
          "Classic ASP LSP Output"
        ]
      }
    ],
    "grammars": [
      {
        "language": "classic-asp",
        "scopeName": "text.html.classic-asp",
        "path": "./syntaxes/classic-asp.tmLanguage.json",
        "embeddedLanguages": {
          "source.vbscript.embedded.asp": "vbscript",
          "source.js": "javascript",
          "source.css": "css",
          "text.html.basic": "html"
        }
      },
      {
        "scopeName": "classic-asp.tag-injection",
        "path": "./syntaxes/classic-asp-tag-injection.tmLanguage.json",
        "injectTo": [
          "text.html.classic-asp"
        ],
        "embeddedLanguages": {
          "source.vbscript.embedded.asp": "vbscript",
          "source.vbscript.embedded.asp.expression": "vbscript"
        }
      },
      {
        "language": "vbscript",
        "scopeName": "source.vbscript",
        "path": "./syntaxes/vbscript.tmLanguage.json"
      },
      {
        "language": "asp-lsp-output",
        "scopeName": "source.asp-lsp-output",
        "path": "./syntaxes/asp-lsp-output.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "support.function.operation.asp-lsp-output",
            "settings": {
              "foreground": "#4FC1FF",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.control.state.asp-lsp-output",
            "settings": {
              "foreground": "#C586C0"
            }
          },
          {
            "scope": "entity.name.function.step.asp-lsp-output",
            "settings": {
              "foreground": "#DCDCAA"
            }
          },
          {
            "scope": "markup.underline.link.uri.asp-lsp-output",
            "settings": {
              "foreground": "#40D86A"
            }
          },
          {
            "scope": "constant.numeric.duration.asp-lsp-output",
            "settings": {
              "foreground": "#8A8A8A",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "constant.numeric.duration.asp-lsp-output.fast",
            "settings": {
              "foreground": "#40D86A"
            }
          },
          {
            "scope": "constant.numeric.duration.asp-lsp-output.medium",
            "settings": {
              "foreground": "#F0C33A"
            }
          },
          {
            "scope": "constant.numeric.duration.asp-lsp-output.slow",
            "settings": {
              "foreground": "#F79333"
            }
          },
          {
            "scope": "constant.numeric.duration.asp-lsp-output.hot",
            "settings": {
              "foreground": "#E84545"
            }
          }
        ]
      }
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "aspLsp.locale": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "ja"
          ],
          "default": "auto",
          "description": "%configuration.locale.description%"
        },
        "aspLsp.defaultLanguage": {
          "type": "string",
          "enum": [
            "VBScript",
            "JScript"
          ],
          "default": "VBScript",
          "description": "%configuration.defaultLanguage.description%"
        },
        "aspLsp.checkJs": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.checkJs.description%"
        },
        "aspLsp.diagnostics.debounceMs": {
          "type": "number",
          "minimum": 0,
          "default": 250,
          "description": "%configuration.diagnostics.debounceMs.description%"
        },
        "aspLsp.debug.output": {
          "type": "string",
          "enum": [
            "off",
            "summary",
            "verbose"
          ],
          "default": "off",
          "description": "%configuration.debug.output.description%"
        },
        "aspLsp.javascript.unusedDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.javascript.unusedDiagnostics.description%"
        },
        "aspLsp.javascript.autoImports": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.javascript.autoImports.description%"
        },
        "aspLsp.javascript.ignoreProjectConfig": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.javascript.ignoreProjectConfig.description%"
        },
        "aspLsp.virtualRoot": {
          "type": "string",
          "default": "",
          "description": "%configuration.virtualRoot.description%"
        },
        "aspLsp.virtualRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.virtualRoots.description%"
        },
        "aspLsp.windowsPathResolution": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.windowsPathResolution.description%"
        },
        "aspLsp.legacyEncoding": {
          "type": "string",
          "enum": [
            "auto",
            "utf8",
            "shift_jis",
            "cp932"
          ],
          "default": "auto",
          "description": "%configuration.legacyEncoding.description%"
        },
        "aspLsp.format.indentSize": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 1,
          "tags": [
            "advanced"
          ],
          "description": "%configuration.format.indentSize.description%"
        },
        "aspLsp.format.indentStyle": {
          "type": "string",
          "enum": [
            "space",
            "tab"
          ],
          "tags": [
            "advanced"
          ],
          "description": "%configuration.format.indentStyle.description%"
        },
        "aspLsp.format.uppercaseKeywords": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.format.uppercaseKeywords.description%"
        },
        "aspLsp.format.alignAssignments": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.format.alignAssignments.description%"
        },
        "aspLsp.format.ignoreVbscriptTagIndent": {
          "type": "boolean",
          "default": false,
          "tags": [
            "advanced"
          ],
          "description": "%configuration.format.ignoreVbscriptTagIndent.description%"
        },
        "aspLsp.format.ignoreCssTagIndent": {
          "type": "boolean",
          "default": false,
          "tags": [
            "advanced"
          ],
          "description": "%configuration.format.ignoreCssTagIndent.description%"
        },
        "aspLsp.format.ignoreJavaScriptTagIndent": {
          "type": "boolean",
          "default": false,
          "tags": [
            "advanced"
          ],
          "description": "%configuration.format.ignoreJavaScriptTagIndent.description%"
        },
        "aspLsp.format.onSave": {
          "type": "boolean",
          "default": false,
          "tags": [
            "advanced"
          ],
          "description": "%configuration.format.onSave.description%"
        },
        "aspLsp.vbscript.typeChecking": {
          "type": "string",
          "enum": [
            "basic",
            "strict"
          ],
          "default": "basic",
          "description": "%configuration.vbscript.typeChecking.description%"
        },
        "aspLsp.vbscript.identifierCase": {
          "type": "string",
          "enum": [
            "PascalCase",
            "UPPERCASE",
            "camelCase",
            "lowercase",
            "snake_case",
            "UPPER_SNAKE",
            "ignore"
          ],
          "default": "ignore",
          "description": "%configuration.vbscript.identifierCase.description%"
        },
        "aspLsp.vbscript.identifierCaseByKind": {
          "type": "object",
          "default": {},
          "description": "%configuration.vbscript.identifierCaseByKind.description%",
          "properties": {
            "variable": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "parameter": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "class": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "function": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "sub": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "constant": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "field": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "property": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            },
            "method": {
              "$ref": "#/contributes/configuration/properties/aspLsp.vbscript.identifierCase"
            }
          },
          "additionalProperties": false
        },
        "aspLsp.vbscript.comTypes": {
          "type": "object",
          "default": {},
          "description": "%configuration.vbscript.comTypes.description%",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "members": {
                "type": "object",
                "description": "%configuration.vbscript.comTypes.members.description%",
                "additionalProperties": {
                  "oneOf": [
                    {
                      "type": "string",
                      "description": "%configuration.vbscript.comTypes.memberString.description%"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "enum": [
                            "field",
                            "property",
                            "method"
                          ],
                          "default": "property"
                        },
                        "type": {
                          "type": "string",
                          "description": "%configuration.vbscript.comTypes.type.description%"
                        },
                        "returnType": {
                          "type": "string",
                          "description": "%configuration.vbscript.comTypes.returnType.description%"
                        },
                        "parameters": {
                          "type": "array",
                          "description": "%configuration.vbscript.comTypes.parameters.description%",
                          "items": {
                            "oneOf": [
                              {
                                "type": "string",
                                "description": "%configuration.vbscript.comTypes.parameterString.description%"
                              },
                              {
                                "type": "object",
                                "required": [
                                  "name"
                                ],
                                "properties": {
                                  "name": {
                                    "type": "string"
                                  },
                                  "type": {
                                    "type": "string"
                                  }
                                },
                                "additionalProperties": false
                              }
                            ]
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              }
            },
            "additionalProperties": false
          }
        },
        "aspLsp.vbscript.globals": {
          "type": "object",
          "default": {},
          "description": "%configuration.vbscript.globals.description%",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string",
                "description": "%configuration.vbscript.globals.string.description%"
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "%configuration.vbscript.globals.type.description%"
                  },
                  "kind": {
                    "type": "string",
                    "enum": [
                      "variable",
                      "constant"
                    ],
                    "default": "variable"
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "aspLsp.vbscript.unusedDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.vbscript.unusedDiagnostics.description%"
        },
        "aspLsp.vbscript.includeSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.vbscript.includeSuggestions.description%"
        },
        "aspLsp.vbscript.syntaxSnippets": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.vbscript.syntaxSnippets.description%"
        },
        "aspLsp.inlayHints.variableTypes": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.inlayHints.variableTypes.description%"
        },
        "aspLsp.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.inlayHints.parameterNames.description%"
        },
        "aspLsp.inlayHints.functionReturnTypes": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.inlayHints.functionReturnTypes.description%"
        },
        "aspLsp.inlayHints.implicitByRef": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.inlayHints.implicitByRef.description%"
        },
        "aspLsp.inlayHints.globalVariableMarkers": {
          "type": "string",
          "enum": [
            "global",
            "all",
            "off"
          ],
          "default": "global",
          "description": "%configuration.inlayHints.globalVariableMarkers.description%"
        },
        "aspLsp.codeLens.references": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.codeLens.references.description%"
        },
        "aspLsp.codeLens.referenceScope": {
          "type": "string",
          "enum": [
            "analyzed",
            "workspace"
          ],
          "default": "analyzed",
          "description": "%configuration.codeLens.referenceScope.description%"
        },
        "aspLsp.codeLens.includes": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.codeLens.includes.description%"
        },
        "aspLsp.cache.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.cache.enabled.description%"
        },
        "aspLsp.cache.directory": {
          "type": "string",
          "default": "",
          "description": "%configuration.cache.directory.description%"
        },
        "aspLsp.cache.ttlHours": {
          "type": "number",
          "minimum": 1,
          "default": 336,
          "description": "%configuration.cache.ttlHours.description%"
        },
        "aspLsp.cache.maxSizeMb": {
          "type": "number",
          "minimum": 1,
          "default": 128,
          "description": "%configuration.cache.maxSizeMb.description%"
        },
        "aspLsp.workspace.maxIndexFiles": {
          "type": "number",
          "minimum": 1,
          "default": 5000,
          "description": "%configuration.workspace.maxIndexFiles.description%"
        },
        "aspLsp.workspace.scanChunkSize": {
          "type": "number",
          "minimum": 1,
          "default": 200,
          "description": "%configuration.workspace.scanChunkSize.description%"
        },
        "aspLsp.workspace.backgroundAnalysis": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.workspace.backgroundAnalysis.description%"
        },
        "aspLsp.workspace.idleAnalysisConcurrency": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "%configuration.workspace.idleAnalysisConcurrency.description%"
        },
        "aspLsp.workspace.busyAnalysisConcurrency": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "%configuration.workspace.busyAnalysisConcurrency.description%"
        },
        "aspLsp.iis.url": {
          "type": "string",
          "default": "http://localhost/",
          "description": "%configuration.iis.url.description%"
        },
        "aspLsp.iis.webRoot": {
          "type": "string",
          "default": "",
          "description": "%configuration.iis.webRoot.description%"
        },
        "aspLsp.iis.browser": {
          "type": "string",
          "default": "pwa-chrome",
          "description": "%configuration.iis.browser.description%"
        },
        "aspLsp.iisExpress.url": {
          "type": "string",
          "default": "http://localhost:8080/",
          "description": "%configuration.iisExpress.url.description%"
        },
        "aspLsp.iisExpress.webRoot": {
          "type": "string",
          "default": "",
          "description": "%configuration.iisExpress.webRoot.description%"
        },
        "aspLsp.iisExpress.browser": {
          "type": "string",
          "default": "pwa-chrome",
          "description": "%configuration.iisExpress.browser.description%"
        }
      }
    },
    "commands": [
      {
        "command": "aspLsp.restartServer",
        "title": "%command.restartServer.title%"
      },
      {
        "command": "aspLsp.reindexWorkspace",
        "title": "%command.reindexWorkspace.title%"
      },
      {
        "command": "aspLsp.clearCache",
        "title": "%command.clearCache.title%"
      },
      {
        "command": "aspLsp.openOutput",
        "title": "%command.openOutput.title%"
      },
      {
        "command": "aspLsp.debugIisUrl",
        "title": "%command.debugIisUrl.title%"
      },
      {
        "command": "aspLsp.debugIisExpressUrl",
        "title": "%command.debugIisExpressUrl.title%"
      },
      {
        "command": "aspLsp.createLaunchConfig",
        "title": "%command.createLaunchConfig.title%"
      }
    ],
    "keybindings": [
      {
        "command": "aspLsp.toggleLineComment",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "editorTextFocus && editorLangId == classic-asp"
      }
    ],
    "problemMatchers": [
      {
        "name": "asp-lsp",
        "owner": "asp-lsp",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.*)\\((\\d+),(\\d+)\\):\\s+(error|warning|info)\\s+([^:]+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "asp-lsp",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "%taskDefinition.task.description%"
          }
        }
      }
    ]
  },
  "activationEvents": [
    "onLanguage:classic-asp"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#6f5bd5",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "%capability.untrustedWorkspaces.description%"
    }
  }
}
