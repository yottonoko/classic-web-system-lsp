{
  "name": "classic-asp-lsp",
  "displayName": "Classic ASP LSP",
  "version": "0.1.0",
  "private": true,
  "description": "Classic ASP language support backed by asp-lsp.",
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "publisher": "yottonoko",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-server-runtime.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint src test --deny-warnings --no-error-on-unmatched-pattern",
    "package:vsix": "pnpm --filter @asp-lsp/language-server run build && pnpm run build && vsce package --allow-missing-repository --no-dependencies --follow-symlinks",
    "test": "pnpm --filter @asp-lsp/language-server run build && pnpm run build && vitest run --passWithNoTests"
  },
  "dependencies": {
    "@asp-lsp/language-server": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "classic-asp",
        "aliases": [
          "Classic ASP",
          "classic-asp",
          "ASP"
        ],
        "extensions": [
          ".asp",
          ".asa",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "classic-asp",
        "scopeName": "text.html.classic-asp",
        "path": "./syntaxes/classic-asp.tmLanguage.json",
        "embeddedLanguages": {
          "source.vbscript.embedded.asp": "vbscript",
          "source.js": "javascript",
          "source.css": "css",
          "text.html.basic": "html"
        }
      }
    ],
    "configuration": {
      "title": "Classic ASP LSP",
      "properties": {
        "aspLsp.defaultLanguage": {
          "type": "string",
          "enum": [
            "VBScript",
            "JScript"
          ],
          "default": "VBScript",
          "description": "Default server-side script language for Classic ASP pages."
        },
        "aspLsp.checkJs": {
          "type": "boolean",
          "default": false,
          "description": "Enable semantic checking for client JavaScript regions."
        },
        "aspLsp.virtualRoot": {
          "type": "string",
          "default": "",
          "description": "Root directory used to resolve virtual include paths."
        },
        "aspLsp.virtualRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional root directories used to resolve virtual include paths."
        },
        "aspLsp.legacyEncoding": {
          "type": "string",
          "enum": [
            "utf8",
            "shift_jis",
            "cp932"
          ],
          "default": "utf8",
          "description": "Encoding used when reading unopened include files."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:classic-asp"
  ],
  "engines": {
    "vscode": "^1.96.0"
  }
}
