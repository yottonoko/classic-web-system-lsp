{
  "name": "@asp-lsp/language-server",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "asp-lsp": "dist/server.js"
  },
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
