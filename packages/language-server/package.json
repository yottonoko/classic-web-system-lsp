{
  "name": "@asp-lsp/language-server",
  "version": "0.5.45",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "bin": {
    "asp-lsp": "dist/server.js"
  },
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint src test --deny-warnings --no-error-on-unmatched-pattern",
    "test": "pnpm --filter @asp-lsp/core run build && pnpm run build && vitest run",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@asp-lsp/core": "workspace:*",
    "cbor-x": "^1.6.4",
    "chardet": "^2.1.1",
    "typescript": "^6.0.3",
    "vscode-css-languageservice": "^6.3.10",
    "vscode-html-languageservice": "^5.6.2",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5"
  }
}
