{
  "name": "asp-lsp-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Classic ASP language server and VS Code extension.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
