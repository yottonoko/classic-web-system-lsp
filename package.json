    "format:check": "oxfmt . --check",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.106.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@11.1.2"
}
